name: DEV-tigacase-auth-client

on:
  workflow_dispatch:

env:
  DOCKER_IMAGE: deploy_image/tigacase-auth-client
  # 仓库名以 origin 为准：git@github.com:lowcode-yunti/tigacase-auth-client.git
  REPOSITORY: lowcode-yunti/tigacase-auth-client
  BRANCH_NAME: main
  DOCKER_REGISTRY: ${{ vars.DOCKER_REGISTRY_SHANGHAI }}
  DOCKER_USERNAME: ${{ vars.DOCKER_USERNAME }}

jobs:
  build-and-push:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout the repository
        uses: actions/checkout@v4
        with:
          repository: ${{ env.REPOSITORY }}
          ref: ${{ env.BRANCH_NAME }}
          token: ${{ secrets.ACTION_TOKEN }}

      - name: Get the latest commit SHA
        id: get-sha
        run: echo "sha=$(git rev-parse HEAD)" >> $GITHUB_OUTPUT

      - name: Get current date
        id: current-date
        run: echo "date=$(TZ=Asia/Shanghai date +'%Y-%m-%d-%H-%M-%S')" >> $GITHUB_OUTPUT

      - name: Login to Docker Registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.DOCKER_REGISTRY }}
          username: ${{ env.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      # 项目根目录结构：
      #   Dockerfile.cython   — Cython 镜像（仅编译 app/services/）
      #   app/                — FastAPI 应用（api/main 保持 .py）
      #   scripts/cythonize_services.py
      #   config/keys.example.json（运行时挂载 keys.json）
      - name: Build and push auth client Docker image (Cython)
        id: build
        uses: docker/build-push-action@v6
        with:
          context: .
          file: ./Dockerfile.cython
          push: true
          platforms: linux/amd64
          tags: |
            ${{ env.DOCKER_REGISTRY }}/${{ env.DOCKER_IMAGE }}:${{ env.BRANCH_NAME }}
            ${{ env.DOCKER_REGISTRY }}/${{ env.DOCKER_IMAGE }}:${{ env.BRANCH_NAME }}-${{ steps.current-date.outputs.date }}
            ${{ env.DOCKER_REGISTRY }}/${{ env.DOCKER_IMAGE }}:${{ steps.get-sha.outputs.sha }}

      - name: Image digest
        run: echo "Image pushed with digest ${{ steps.build.outputs.digest }}"
